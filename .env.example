# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://app:password@localhost:5432/newstiktok

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MinIO ─────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=news-videos
MINIO_USE_SSL=false

# ── GenAIPro ──────────────────────────────────────────────────────────
GENAIPRO_API_KEY=
GENAIPRO_BASE_URL=https://genaipro.vn/api

# ── OpenRouter ────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ── OpenAI (Whisper) ──────────────────────────────────────────────────
OPENAI_API_KEY=

# ── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Encryption (must be exactly 32 bytes) ─────────────────────────────
ENCRYPTION_KEY=change-me-32-byte-key-for-aes256

# ── Pipeline ──────────────────────────────────────────────────────────
MAX_CONCURRENT_VIDEOS=10
BROLL_COUNT=15
BROLL_DURATION_SECONDS=6
BROLL_BATCH_SIZE=10

# ── noVNC / CDP ──────────────────────────────────────────────────────
NOVNC_URL=http://localhost:6080
CDP_URL=http://localhost:9222

# ── General ───────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]
